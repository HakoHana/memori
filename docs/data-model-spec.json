    "user_persona": {
      "table": "user_persona",
      "description": "用户画像 — LLM 生成的用户特征摘要，增量+全量双模式更新",

      "write_spec": {
        "required_on_create": [
          {"field": "uid",        "type": "string", "description": "规范用户 ID（PK）"}
        ],
        "optional_on_create": [
          {"field": "summary",              "type": "string", "default": "",        "description": "画像摘要（短文本）"},
          {"field": "full_markdown",        "type": "string", "default": "",        "description": "完整画像 Markdown"},
          {"field": "tags",                 "type": "string[]", "default": "[]",    "description": "特征标签列表（JSON 数组）"},
          {"field": "known_ids",            "type": "string[]", "default": "[]",    "description": "已知的身份标识"},
          {"field": "primary_name",         "type": "string", "default": "",        "description": "首选名字"},
          {"field": "identity_confidence",  "type": "float",  "default": 0.3,       "description": "身份可信度"},
          {"field": "tier",                 "type": "enum",   "values": ["new","known","trusted","core"], "default": "new", "description": "用户等级"}
        ],
        "auto_generated": [
          {"field": "version",                  "type": "integer", "default": 1,     "source": "全量重建时 +1"},
          {"field": "incremental_count",        "type": "integer", "default": 0,     "source": "每次增量更新 +1"},
          {"field": "diary_count_since_full",   "type": "integer", "default": 0,     "source": "全量重建后日记计数"},
          {"field": "last_full_update",         "type": "float",                      "source": "全量重建时记录"},
          {"field": "last_incremental_update",  "type": "float",                      "source": "增量更新时记录"},
          {"field": "created_at",               "type": "float",  "format": "unix_timestamp", "source": "time.time()"},
          {"field": "updated_at",               "type": "float",  "format": "unix_timestamp", "source": "time.time()，更新时刷新"}
        ],
        "updatable_fields": [
          {"field": "summary",           "type": "string",  "description": "更新画像摘要"},
          {"field": "full_markdown",     "type": "string",  "description": "更新完整画像"},
          {"field": "tags",              "type": "string[]","description": "更新标签列表"},
          {"field": "tier",              "type": "enum",    "description": "调整用户等级"}
        ]
      },

      "query_spec": {
        "primary_keys": [
          {"field": "uid",        "type": "string", "op": "=", "description": "主键精确查找"}
        ],
        "secondary_indexes": [
          {"field": "tier",         "type": "enum",   "op": "=",       "description": "按用户等级过滤"},
          {"field": "tags",         "type": "string[]","op": "LIKE",   "description": "按标签模糊搜索（JSON 文本）"},
          {"field": "last_full_update",    "type": "float",  "op": ["ORDER BY", "BETWEEN"], "description": "按全量更新时间"},
          {"field": "last_incremental_update", "type": "float", "op": ["ORDER BY", "BETWEEN"], "description": "按增量更新时间"}
        ],
        "common_query_patterns": [
          {"name": "获取用户画像",          "sql_hint": "SELECT summary, tags, tier FROM user_persona WHERE uid=?"},
          {"name": "用户列表排序",          "sql_hint": "LEFT JOIN canonical_users ORDER BY last_incremental_update DESC"},
          {"name": "增量超阈值触发全量",     "sql_hint": "WHERE incremental_count >= 10 OR diary_count_since_full >= 50"},
          {"name": "新用户（无画像）过滤",   "sql_hint": "WHERE summary IS NULL"}
        ]
      }
    },

    "user_registry": {
      "table": "user_registry",
      "description": "用户注册表 — 记录 user_id 到可读名字的映射",

      "write_spec": {
        "required_on_create": [
          {"field": "user_id",      "type": "string", "description": "用户 ID（PK）"}
        ],
        "optional_on_create": [
          {"field": "user_name",    "type": "string", "default": "", "description": "可读名字"}
        ],
        "auto_generated": [
          {"field": "first_seen_at",    "type": "float", "format": "unix_timestamp", "source": "time.time()"},
          {"field": "last_seen_at",     "type": "float", "format": "unix_timestamp", "source": "每次活跃刷新"},
          {"field": "name_updated_at",  "type": "float", "format": "unix_timestamp", "source": "改名时记录"}
        ],
        "updatable_fields": [
          {"field": "user_name",    "type": "string", "description": "更新显示名"},
          {"field": "last_seen_at", "type": "float",  "description": "记录活跃时间"}
        ]
      },

      "query_spec": {
        "primary_keys": [
          {"field": "user_id",    "type": "string", "op": "=", "description": "主键精确查找"}
        ]
      }
    },

    "sessions": {
      "table": "sessions",
      "description": "会话列表 — 消息会话的元数据",

      "write_spec": {
        "required_on_create": [
          {"field": "session_id", "type": "string", "description": "会话 ID（PK）"},
          {"field": "user_id",    "type": "string", "description": "所属用户"}
        ],
        "optional_on_create": [
          {"field": "platform",   "type": "string", "default": "", "description": "平台标识"},
          {"field": "metadata",   "type": "json",   "default": "{}", "description": "会话元数据"}
        ],
        "auto_generated": [
          {"field": "created_at",     "type": "float", "format": "unix_timestamp", "source": "time.time()"},
          {"field": "last_active_at", "type": "float", "format": "unix_timestamp", "source": "每次消息时刷新"},
          {"field": "message_count",  "type": "integer", "default": 0,              "source": "自动累计"}
        ],
        "updatable_fields": [
          {"field": "last_active_at", "type": "float",  "description": "更新活跃时间"},
          {"field": "message_count",  "type": "integer", "description": "更新消息数"},
          {"field": "metadata",       "type": "json",   "description": "更新元数据"}
        ]
      },

      "query_spec": {
        "primary_keys": [
          {"field": "session_id", "type": "string", "op": "=", "description": "主键精确查找"}
        ],
        "secondary_indexes": [
          {"field": "user_id",      "type": "string", "op": "=",      "description": "按用户过滤"},
          {"field": "last_active_at","type": "float",  "op": "ORDER BY", "description": "按活跃时间排序"}
        ],
        "common_query_patterns": [
          {"name": "用户会话列表",        "sql_hint": "WHERE user_id=? ORDER BY last_active_at DESC"},
          {"name": "最近活跃会话",        "sql_hint": "ORDER BY last_active_at DESC LIMIT ?"},
          {"name": "不活跃过期会话",      "sql_hint": "WHERE last_active_at < ?"}
        ]
      }
    },

    "messages": {
      "table": "messages",
      "description": "消息记录 — 对话中的每条消息",

      "write_spec": {
        "required_on_create": [
          {"field": "session_id",   "type": "string", "description": "所属会话 ID"},
          {"field": "role",         "type": "enum",   "values": ["user","assistant","system"], "description": "消息角色"},
          {"field": "content",      "type": "string", "description": "消息内容"}
        ],
        "optional_on_create": [
          {"field": "sender_id",    "type": "string", "default": "",   "description": "发送者 ID"},
          {"field": "sender_name",  "type": "string", "default": "",   "description": "发送者名字"},
          {"field": "metadata",     "type": "json",   "default": "{}", "description": "消息元数据"}
        ],
        "auto_generated": [
          {"field": "id",           "type": "integer", "source": "AUTOINCREMENT",  "description": "主键 ID"},
          {"field": "timestamp",    "type": "float",   "format": "unix_timestamp", "source": "time.time()"}
        ]
      },

      "query_spec": {
        "primary_keys": [
          {"field": "id",           "type": "integer", "op": "=", "description": "主键"}
        ],
        "secondary_indexes": [
          {"field": "session_id",   "type": "string", "op": "=",       "description": "按会话取消息列表"},
          {"field": "session_id + id", "type": "composite", "op": "ORDER BY DESC", "description": "复合索引：会话消息时间线"},
          {"field": "role",         "type": "string", "op": "=",       "description": "按角色过滤"},
          {"field": "timestamp",    "type": "float",  "op": "BETWEEN", "description": "时间范围查询"}
        ],
        "common_query_patterns": [
          {"name": "会话消息时间线",     "sql_hint": "WHERE session_id=? ORDER BY id ASC"},
          {"name": "最近 N 条消息",      "sql_hint": "WHERE session_id=? ORDER BY id DESC LIMIT ?"},
          {"name": "用户最近发言",       "sql_hint": "WHERE session_id=? AND role='user' ORDER BY id DESC LIMIT ?"}
        ]
      }
    },

    "consolidation_state": {
      "table": "consolidation_state",
      "description": "整理状态 — 记录每个用户的 ConsolidationManager 进度",

      "write_spec": {
        "required_on_create": [
          {"field": "user_id",    "type": "string", "description": "用户 ID（PK）"}
        ],
        "optional_on_create": [
          {"field": "msg_count",                     "type": "integer", "default": 0, "description": "本周期消息数"},
          {"field": "warmup_threshold",               "type": "integer", "default": 1, "description": "暖启动阈值（0=已完成）"},
          {"field": "last_consolidated_at",           "type": "float",   "default": 0, "description": "上次整理时间"},
          {"field": "last_diary_date",                "type": "string",  "default": "", "description": "最后日记日期"},
          {"field": "diary_count",                    "type": "integer", "default": 0, "description": "累计日记数"},
          {"field": "diary_count_since_persona",      "type": "integer", "default": 0, "description": "上次画像后日记数"},
          {"field": "l1_retry_count",                 "type": "integer", "default": 0, "description": "L1 重试计数"}
        ],
        "write_behavior": "INSERT OR REPLACE（全字段覆盖），每次整理后 reset_after_consolidation()",
        "auto_generated": []
      },

      "query_spec": {
        "primary_keys": [
          {"field": "user_id",  "type": "string", "op": "=", "description": "主键精确查找"}
        ],
        "common_query_patterns": [
          {"name": "加载用户状态", "sql_hint": "SELECT * FROM consolidation_state WHERE user_id=?"}
        ]
      }
    },

    "entity_cooccur": {
      "table": "entity_cooccur",
      "description": "实体共现表 — 记录两个实体在同篇日记中同时出现的频次",

      "write_spec": {
        "required_on_create": [
          {"field": "entity_a_id",  "type": "integer", "description": "实体 A 的 graph_nodes.id"},
          {"field": "entity_b_id",  "type": "integer", "description": "实体 B 的 graph_nodes.id"}
        ],
        "auto_generated": [
          {"field": "count",        "type": "integer", "default": 1,  "source": "共现则 +1"},
          {"field": "last_updated", "type": "string",  "format": "ISO-8601", "source": "自动记录"}
        ],
        "upsert_merge": [
          {"field": "count",        "operation": "increment", "description": "每次共现 count +1"}
        ]
      },

      "query_spec": {
        "primary_keys": [
          {"field": "entity_a_id + entity_b_id", "type": "composite", "op": "=", "description": "复合主键"}
        ],
        "secondary_indexes": [
          {"field": "entity_a_id",  "type": "integer", "op": "=",  "description": "正向查找"},
          {"field": "entity_b_id",  "type": "integer", "op": "=",  "description": "反向查找"}
        ],
        "common_query_patterns": [
          {"name": "某实体的共现实体", "sql_hint": "WHERE entity_a_id=? OR entity_b_id=? ORDER BY count DESC"}
        ]
      }
    },

    "write_ops": {
      "table": "write_ops",
      "description": "写操作日志 — 多步写入的崩溃恢复",

      "write_spec": {
        "required_on_create": [
          {"field": "op_type",  "type": "string", "description": "操作类型，如 consolidation, persona_update, import"}
        ],
        "optional_on_create": [
          {"field": "payload",  "type": "json",  "default": "{}", "description": "操作负载"}
        ],
        "auto_generated": [
          {"field": "id",           "type": "integer", "source": "AUTOINCREMENT",  "description": "主键 ID"},
          {"field": "status",       "type": "enum",    "values": ["pending","completed","failed"], "default": "pending", "source": "程序初始值"},
          {"field": "step",         "type": "string",  "default": "started",       "source": "程序初始值"},
          {"field": "retry_count",  "type": "integer", "default": 0,               "source": "程序初始值"},
          {"field": "error",        "type": "string",  "nullable": true,           "source": "失败时记录"},
          {"field": "created_at",   "type": "float",   "format": "unix_timestamp", "source": "time.time()"},
          {"field": "updated_at",   "type": "float",   "format": "unix_timestamp", "source": "每一步更新"}
        ],
        "updatable_fields": [
          {"field": "status",     "type": "enum",   "description": "更新状态"},
          {"field": "step",       "type": "string", "description": "更新进度"},
          {"field": "error",      "type": "string", "description": "记录错误"}
        ]
      },

      "query_spec": {
        "primary_keys": [
          {"field": "id",       "type": "integer", "op": "=", "description": "主键"}
        ],
        "secondary_indexes": [
          {"field": "status + updated_at", "type": "composite", "op": "范围", "description": "复合索引：找到卡住/失败的操作"}
        ],
        "common_query_patterns": [
          {"name": "查找卡住的操作",  "sql_hint": "WHERE status='pending' AND updated_at < ? ORDER BY created_at"},
          {"name": "按操作类型查找",  "sql_hint": "WHERE op_type=? ORDER BY created_at DESC"}
        ]
      }
    }

  },

  "cross_model_relations": [
    {
      "from": "memory_atoms",
      "to": "diary_entries",
      "via": "diary_id",
      "type": "N:1",
      "description": "多个原子关联到同一篇日记"
    },
    {
      "from": "memory_atoms",
      "to": "atomic_facts",
      "via": "content 去重",
      "type": "M:N (通过 diary_fact_links)",
      "description": "v4 去重架构：原子写入时先查询 atomic_facts 是否已存在"
    },
    {
      "from": "diary_entries",
      "to": "atomic_facts",
      "via": "diary_fact_links",
      "type": "M:N",
      "description": "一篇日记关联多个事实，一个事实出现在多篇日记"
    },
    {
      "from": "graph_edges",
      "to": "graph_nodes",
      "via": "source_node_id / target_node_id",
      "type": "N:1 + 1:N",
      "description": "边引用节点（外键约束）"
    },
    {
      "from": "user_identities",
      "to": "canonical_users",
      "via": "uid",
      "type": "M:1",
      "description": "多个平台身份映射到一个规范用户"
    },
    {
      "from": "user_persona",
      "to": "canonical_users",
      "via": "uid",
      "type": "1:1",
      "description": "一个规范用户对应一个画像"
    },
    {
      "from": "sessions",
      "to": "messages",
      "via": "session_id",
      "type": "1:N",
      "description": "一个会话包含多条消息"
    }
  ],

  "write_rules_summary": {
    "create_required_behaviors": [
      "INSERT 前调用 MemoryAtom.prepare_insert() 自动计算 expires_at 和 decay_type",
      "INSERT 后同步写入 FTS5 索引 (memory_atoms_fts / diary_fts)",
      "原子批量插入在单个事务内完成（避免多次 commit）",
      "user_identities 创建时触发 canonical_users 的创建或更新",
      "diary_fact_links 使用 INSERT OR IGNORE 避免重复",
      "写操作日志 (write_ops) 记录多步操作的每一步，用于崩溃恢复"
    ],
    "update_rules": [
      "memory_atoms 只允许更新 content, atom_type, importance, status 四个字段",
      "diary_entries 更新 content 后需同步 frontmatter 到 DB 字段",
      "user_persona 增量更新时 incremental_count +1；全量更新时 +1 并重置计数器为 0",
      "atomic_facts 重复时 source_count +1，importance 取 max（+0.05 保底）",
      "软删除用 status='forgotten' 代替 DELETE"
    ],
    "query_rules": [
      "所有活跃查询默认加 WHERE status='active' 过滤",
      "FTS5 查询使用 BM25 + importance 加权混合排序",
      "内存_atoms 的过期清理扫描 status + ttl_days 复合索引",
      "所有列表查询支持分页：LIMIT ? OFFSET ?",
      "用户列表默认按 last_incremental_update DESC NULLS LAST 排序"
    ]
  }
}
